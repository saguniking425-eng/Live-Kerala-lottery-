rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    // --- Validation Blueprints ---
    function isValidLotteryResult(data) {
      return data.keys().hasAll(['date', 'lotteryName', 'drawNo', 'tier', 'series', 'number', 'last4', 'amount'])
        && data.date is string && data.date.size() == 10
        && data.lotteryName is string && data.lotteryName.size() <= 100
        && data.number is string && data.number.size() <= 10;
    }

    function isValidForecast(data) {
      return data.keys().hasAll(['date', 'targetLottery', 'predictedSegments', 'confidenceScore', 'analysisBasis'])
        && data.date is string && data.date.size() == 10
        && data.confidenceScore is number
        && data.predictedSegments is string;
    }

    function isValidAlert(data) {
      return data.keys().hasAll(['userId', 'type', 'value', 'createdAt', 'isActive'])
        && data.keys().size() == 5
        && data.userId == request.auth.uid
        && data.type in ['number', 'pattern', 'lottery']
        && data.value is string && data.value.size() > 0 && data.value.size() <= 64
        && data.isActive is bool
        && data.createdAt == request.time;
    }

    function isValidReport(data) {
      return data.keys().hasAll(['date', 'lotteryName', 'report'])
        && data.date is string && data.date.size() == 10
        && data.lotteryName is string && data.lotteryName.size() <= 100
        && data.report is string;
    }

    // --- Collection Rules ---

    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    // Lottery Draws: Publicly readable for the dashboard.
    // Writes are permitted from the server.
    match /lottery_draws/{drawId} {
      allow read: if true;
      allow create: if isValidLotteryResult(incoming());
      allow update: if isVerified(); // Allow updates for rectifications
      allow delete: if false; // Deny deletes for production records
    }

    // AI Reports: Summary reports generated by the engine.
    match /reports/{dateId} {
      allow read: if true;
      allow create: if isValidReport(incoming());
      allow update, delete: if isVerified();
    }

    // Forecasts: AI predictions.
    match /forecasts/{dateId} {
      allow read: if true;
      allow create: if isValidForecast(incoming());
      allow update, delete: if isVerified();
    }

    // User-specific Alerts
    match /users/{userId}/alerts/{alertId} {
      allow read: if isVerified() && request.auth.uid == userId;
      allow create: if isVerified() && request.auth.uid == userId && isValidAlert(incoming());
      allow update: if isVerified() && request.auth.uid == userId && isValidAlert(incoming()) && incoming().diff(existing()).affectedKeys().hasOnly(['isActive']);
      allow delete: if isVerified() && request.auth.uid == userId;
    }

    // Saved Forecasts
    match /users/{userId}/saved_forecasts/{forecastId} {
      allow read, delete: if isSignedIn() && request.auth.uid == userId;
      allow create: if isSignedIn() && request.auth.uid == userId && isValidForecast(incoming());
    }
    
    // Connection test document
    match /test/connection {
      allow read: if true;
    }
  }
}
