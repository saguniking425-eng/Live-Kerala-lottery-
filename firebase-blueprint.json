{
  "entities": {
    "LotteryResult": {
      "title": "Lottery Result",
      "description": "A single winning number record for a specific prize tier.",
      "type": "object",
      "properties": {
        "date": { "type": "string", "format": "date", "description": "YYYY-MM-DD" },
        "lotteryName": { "type": "string" },
        "drawNo": { "type": "string" },
        "tier": { "type": "string" },
        "series": { "type": "string" },
        "number": { "type": "string" },
        "last4": { "type": "string" },
        "amount": { "type": "number" }
      },
      "required": ["date", "lotteryName", "drawNo", "tier", "number"]
    },
    "AIReport": {
      "title": "AI Analytics Report",
      "description": "Daily intelligence report generated by Gemini.",
      "type": "object",
      "properties": {
        "date": { "type": "string", "format": "date" },
        "lotteryName": { "type": "string" },
        "reportText": { "type": "string" },
        "patternsDetected": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["date", "lotteryName", "reportText"]
    },
    "Forecast": {
      "title": "Predictive Forecast",
      "description": "AI-generated prediction for the next day's draw.",
      "type": "object",
      "properties": {
        "date": { "type": "string", "format": "date", "description": "Target date for the prediction" },
        "targetLottery": { "type": "string" },
        "predictedSegments": { "type": "string" },
        "confidenceScore": { "type": "number" },
        "analysisBasis": { "type": "string" }
      },
      "required": ["date", "targetLottery", "predictedSegments"]
    },
    "UserAlert": {
      "title": "User Alert",
      "description": "Custom notification trigger set by a user.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["number", "pattern", "lottery"] },
        "value": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "isActive": { "type": "boolean" }
      },
      "required": ["userId", "type", "value"]
    },
    "SyncLog": {
      "title": "Sync Operation Log",
      "description": "Recorded trace of an automated or manual synchronization attempt.",
      "type": "object",
      "properties": {
        "date": { "type": "string" },
        "status": { "type": "string", "enum": ["success", "error"] },
        "message": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["date", "status", "message"]
    }
  },
  "firestore": {
    "lottery_draws/{drawId}": {
      "schema": "LotteryResult",
      "description": "Individual winning numbers organized by draw ID."
    },
    "reports/{dateId}": {
      "schema": "AIReport",
      "description": "Daily AI-generated analytics reports."
    },
    "forecasts/{dateId}": {
      "schema": "Forecast",
      "description": "Daily predictive forecasts for upcoming draws."
    },
    "users/{userId}/alerts/{alertId}": {
      "schema": "UserAlert",
      "description": "User-specific lottery result alerts."
    },
    "users/{userId}/saved_forecasts/{forecastId}": {
      "schema": "Forecast",
      "description": "Forecasts saved by the user."
    },
    "sync_logs/{logId}": {
      "schema": "SyncLog",
      "description": "Audit trail for system sync operations."
    }
  }
}
